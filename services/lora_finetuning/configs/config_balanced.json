{
  "model_name": "meta-llama/Llama-2-7b-chat",
  "dtype": "bfloat16",
  "use_flash_attention": true,
  "gradient_checkpointing": true,
  "gradient_accumulation_steps": 4,
  "per_device_train_batch_size": 2,
  "per_device_eval_batch_size": 4,
  "lora_r": 64,
  "lora_alpha": 128,
  "lora_dropout": 0.05,
  "lora_target_modules": "q_proj,v_proj,k_proj,o_proj",
  "num_train_epochs": 3,
  "learning_rate": 0.0002,
  "weight_decay": 0.01,
  "warmup_ratio": 0.03,
  "lr_scheduler_type": "cosine",
  "optim": "paged_adamw_32bit",
  "max_grad_norm": 1.0,
  "max_seq_length": 2048,
  "eval_strategy": "steps",
  "eval_steps": 100,
  "save_strategy": "steps",
  "save_steps": 100,
  "save_total_limit": 3,
  "logging_steps": 10,
  "log_level": "info",
  "train_data_path": "services/lora_finetuning/training_data/train.jsonl",
  "validation_data_path": "services/lora_finetuning/training_data/val.jsonl",
  "output_dir": "lora_checkpoints/gender_bias_h100",
  "use_deepspeed": false,
  "deepspeed_config_path": null,
  "preprocessing_num_workers": 8,
  "overwrite_cache": false,
  "fp16": false,
  "bf16": true,
  "seed": 42,
  "dataloader_pin_memory": true,
  "dataloader_num_workers": 4,
  "remove_unused_columns": false,
  "report_to": "tensorboard,wandb"
}